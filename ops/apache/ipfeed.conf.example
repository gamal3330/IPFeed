<VirtualHost *:80>
    ServerName ipfeed.example.com

    # Serve only the web directory. Keep runtime state in /var/lib/ipfeed.
    DocumentRoot /var/www/IPFeed/ipfeed

    SetEnv IP_FEED_PROJECT_DIR /var/www/IPFeed
    SetEnv IP_FEED_SETTINGS_DIR /var/lib/ipfeed
    SetEnv IP_FEED_CONFIG_FILE /var/lib/ipfeed/config.php
    SetEnv IP_FEED_FEED_FILE /var/www/IPFeed/ipfeed/ips.txt

    <Directory /var/www/IPFeed/ipfeed>
        Options -Indexes +FollowSymLinks
        AllowOverride All
        Require all granted
    </Directory>

    <Directory /var/www/IPFeed/ipfeed/app>
        Require all denied
    </Directory>

    <Directory /var/lib/ipfeed>
        Require all denied
    </Directory>

    # If you use PHP-FPM instead of mod_php, adjust the socket version.
    <FilesMatch "\.php$">
        SetHandler "proxy:unix:/run/php/php8.2-fpm.sock|fcgi://localhost/"
    </FilesMatch>

    DirectoryIndex index.php
    ErrorLog ${APACHE_LOG_DIR}/ipfeed-error.log
    CustomLog ${APACHE_LOG_DIR}/ipfeed-access.log combined
</VirtualHost>
